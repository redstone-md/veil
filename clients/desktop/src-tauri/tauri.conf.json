{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Veil",
  "version": "0.0.1",
  "identifier": "org.veil.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Veil",
        "width": 860,
        "height": 600,
        "minWidth": 720,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "shortDescription": "Veil VPN client",
    "longDescription": "Self-hosted, censorship-resistant VPN client.",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/redstone-md/veil/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI2REVFODgyMTQ4NUZFRTUKUldUbC9vVVVndWplSm4zRUduWXE4cElmYm0zM3h4QzF0Q2VFN0tIZ3g5SUtSMTI1WGY1R2llcE4K"
    }
  }
}
