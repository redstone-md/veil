{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Veil",
  "version": "0.0.1",
  "identifier": "org.veil.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Veil",
        "width": 560,
        "height": 720,
        "minWidth": 480,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "shortDescription": "Veil VPN client",
    "longDescription": "Self-hosted, censorship-resistant VPN client.",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "resources": {
        "../../../sdks/veil-rs/veil.dll": "veil.dll",
        "vendor/wintun.dll": "wintun.dll"
      }
    }
  }
}
